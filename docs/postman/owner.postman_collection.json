{
  "info": {
    "name": "Memoir — Owner Management (EPIC-03)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "EPIC-03: Owner Management endpoints — Kiosk CRUD, Template CRUD, Template Element CRUD, Asset Upload"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api/v1" },
    { "key": "accessToken", "value": "" },
    { "key": "kioskId", "value": "" },
    { "key": "templateId", "value": "" },
    { "key": "elementId", "value": "" }
  ],
  "item": [
    {
      "name": "Kiosks",
      "item": [
        {
          "name": "List kiosks",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/owner/kiosks"
          }
        },
        {
          "name": "Create kiosk (defaults)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/owner/kiosks",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Booth A\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('kioskId', body.data.kiosk.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Create kiosk (custom prices)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/owner/kiosks",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Premium Booth\",\n  \"priceBaseSession\": 50000,\n  \"pricePerExtraPrint\": 10000,\n  \"priceDigitalCopy\": 20000,\n  \"isActive\": true\n}"
            }
          }
        },
        {
          "name": "Create kiosk — 403 no subscription",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/owner/kiosks",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Should Fail\"\n}"
            }
          }
        },
        {
          "name": "Update kiosk",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/owner/kiosks/{{kioskId}}",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Booth\",\n  \"priceBaseSession\": 35000\n}"
            }
          }
        },
        {
          "name": "Update kiosk — 404 not found",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/owner/kiosks/00000000-0000-0000-0000-000000000000",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Ghost\"\n}"
            }
          }
        },
        {
          "name": "Generate pairing code",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/owner/kiosks/{{kioskId}}/generate-pairing"
          }
        },
        {
          "name": "Generate pairing — 404 not found",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/owner/kiosks/00000000-0000-0000-0000-000000000000/generate-pairing"
          }
        }
      ]
    },
    {
      "name": "Templates",
      "item": [
        {
          "name": "List templates",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/owner/templates"
          }
        },
        {
          "name": "Create template",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/owner/templates",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Classic\",\n  \"height\": 864,\n  \"backgroundUrl\": \"https://storage/templates/owner-1/backgrounds/bg.png\",\n  \"overlayUrl\": null,\n  \"isActive\": true\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('templateId', body.data.template.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Create template — 400 bad asset URL",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/owner/templates",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Bad\",\n  \"height\": 864,\n  \"backgroundUrl\": \"https://storage/templates/OTHER-OWNER/bg.png\"\n}"
            }
          }
        },
        {
          "name": "Get template by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/owner/templates/{{templateId}}"
          }
        },
        {
          "name": "Update template",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/owner/templates/{{templateId}}",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Classic\",\n  \"overlayUrl\": null\n}"
            }
          }
        },
        {
          "name": "Delete template",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/owner/templates/{{templateId}}"
          }
        },
        {
          "name": "Delete template — 409 has transactions",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/owner/templates/{{templateId}}"
          }
        }
      ]
    },
    {
      "name": "Template Elements",
      "item": [
        {
          "name": "List elements",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/owner/templates/{{templateId}}/elements"
          }
        },
        {
          "name": "Create element (photo_slot)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/owner/templates/{{templateId}}/elements",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"elementType\": \"photo_slot\",\n  \"sequence\": 1,\n  \"x\": 0,\n  \"y\": 0,\n  \"width\": 200,\n  \"height\": 300,\n  \"rotation\": 0,\n  \"opacity\": 100,\n  \"properties\": { \"captureOrder\": 1 }\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('elementId', body.data.element.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Create element (text)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/owner/templates/{{templateId}}/elements",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"elementType\": \"text\",\n  \"sequence\": 2,\n  \"x\": 10,\n  \"y\": 800,\n  \"width\": 200,\n  \"height\": 40,\n  \"rotation\": 0,\n  \"opacity\": 100,\n  \"properties\": { \"content\": \"Photo Date: {date}\" }\n}"
            }
          }
        },
        {
          "name": "Create element — 409 duplicate sequence",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/owner/templates/{{templateId}}/elements",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"elementType\": \"image\",\n  \"sequence\": 1,\n  \"x\": 0,\n  \"y\": 0,\n  \"width\": 100,\n  \"height\": 100,\n  \"rotation\": 0,\n  \"opacity\": 100,\n  \"properties\": {}\n}"
            }
          }
        },
        {
          "name": "Create element — 400 photo_slot missing captureOrder",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/owner/templates/{{templateId}}/elements",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"elementType\": \"photo_slot\",\n  \"sequence\": 3,\n  \"x\": 0,\n  \"y\": 0,\n  \"width\": 200,\n  \"height\": 300,\n  \"rotation\": 0,\n  \"opacity\": 100,\n  \"properties\": {}\n}"
            }
          }
        },
        {
          "name": "Update element",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/owner/templates/{{templateId}}/elements/{{elementId}}",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"x\": 50,\n  \"y\": 100,\n  \"width\": 250\n}"
            }
          }
        },
        {
          "name": "Update element — 409 sequence conflict",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/owner/templates/{{templateId}}/elements/{{elementId}}",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sequence\": 2\n}"
            }
          }
        },
        {
          "name": "Delete element",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/owner/templates/{{templateId}}/elements/{{elementId}}"
          }
        },
        {
          "name": "Delete element — 400 last photo_slot",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/owner/templates/{{templateId}}/elements/{{elementId}}"
          }
        }
      ]
    },
    {
      "name": "Asset Upload",
      "item": [
        {
          "name": "Upload asset (background)",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/owner/assets/upload?folder=backgrounds",
              "host": ["{{baseUrl}}"],
              "path": ["owner", "assets", "upload"],
              "query": [{ "key": "folder", "value": "backgrounds" }]
            },
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": ""
                }
              ]
            }
          }
        },
        {
          "name": "Upload asset (overlay)",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/owner/assets/upload?folder=overlays",
              "host": ["{{baseUrl}}"],
              "path": ["owner", "assets", "upload"],
              "query": [{ "key": "folder", "value": "overlays" }]
            },
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": ""
                }
              ]
            }
          }
        },
        {
          "name": "Upload asset — 400 unsupported type",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/owner/assets/upload",
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": ""
                }
              ]
            }
          }
        }
      ]
    }
  ]
}
