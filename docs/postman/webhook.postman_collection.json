{
  "info": {
    "name": "memoir. API — Webhooks",
    "description": "Xendit webhook callback endpoint for payment status updates (QRIS transactions and subscription invoices).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api/v1" },
    { "key": "webhookToken", "value": "" }
  ],
  "item": [
    {
      "name": "Xendit Webhook — QRIS Payment Success",
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}/webhooks/xendit",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "x-callback-token", "value": "{{webhookToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"event\": \"payment.capture\",\n  \"business_id\": \"test-business-id\",\n  \"created\": \"2026-03-15T12:00:00.000Z\",\n  \"data\": {\n    \"type\": \"PAY\",\n    \"status\": \"SUCCEEDED\",\n    \"country\": \"ID\",\n    \"currency\": \"IDR\",\n    \"payment_id\": \"py-test-123\",\n    \"channel_code\": \"QRIS\",\n    \"reference_id\": \"MEM-1710499200000-a1b2c3\",\n    \"request_amount\": 25000,\n    \"capture_method\": \"AUTOMATIC\",\n    \"captures\": [\n      {\n        \"capture_id\": \"cptr-test-456\",\n        \"capture_amount\": 25000,\n        \"capture_timestamp\": \"2026-03-15T12:00:30.000Z\"\n      }\n    ],\n    \"payment_request_id\": \"pr-test-789\"\n  }\n}"
        },
        "description": "Simulates a successful QRIS payment webhook from Xendit. reference_id must match an existing transaction orderId with MEM- prefix."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('200 OK', () => pm.response.to.have.status(200));",
              "pm.test('returns ok status', () => {",
              "  pm.expect(pm.response.json().status).to.eql('ok');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Xendit Webhook — Subscription Invoice Paid",
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}/webhooks/xendit",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "x-callback-token", "value": "{{webhookToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"event\": \"payment.capture\",\n  \"business_id\": \"test-business-id\",\n  \"created\": \"2026-03-15T12:00:00.000Z\",\n  \"data\": {\n    \"type\": \"PAY\",\n    \"status\": \"PAID\",\n    \"country\": \"ID\",\n    \"currency\": \"IDR\",\n    \"payment_id\": \"py-test-sub-123\",\n    \"channel_code\": \"XENDIT\",\n    \"reference_id\": \"SUB-1710499200000-d4e5f6\",\n    \"request_amount\": 99000,\n    \"payment_request_id\": \"pr-test-sub-789\"\n  }\n}"
        },
        "description": "Simulates a subscription invoice payment webhook. reference_id must match an existing subscription invoice orderId with SUB- prefix."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('200 OK', () => pm.response.to.have.status(200));",
              "pm.test('returns ok status', () => {",
              "  pm.expect(pm.response.json().status).to.eql('ok');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "ERR: Xendit Webhook — Invalid Token",
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}/webhooks/xendit",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "x-callback-token", "value": "invalid-token" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"event\": \"payment.capture\",\n  \"business_id\": \"test\",\n  \"created\": \"2026-03-15T12:00:00.000Z\",\n  \"data\": {\n    \"type\": \"PAY\",\n    \"status\": \"SUCCEEDED\",\n    \"country\": \"ID\",\n    \"currency\": \"IDR\",\n    \"payment_id\": \"py-test\",\n    \"channel_code\": \"QRIS\",\n    \"reference_id\": \"MEM-123-abc\",\n    \"request_amount\": 10000\n  }\n}"
        },
        "description": "Should return 401 when x-callback-token does not match."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('401 Unauthorized', () => {",
              "  pm.response.to.have.status(401);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    }
  ]
}
