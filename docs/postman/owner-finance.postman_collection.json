{
  "info": {
    "name": "Memoir API — Owner Finance",
    "_postman_id": "epic-04-owner-finance",
    "description": "EPIC-04: Owner Finance — Wallet, Transactions & Withdrawals",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api/v1"
    },
    {
      "key": "accessToken",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Transactions",
      "item": [
        {
          "name": "GET /owner/transactions — Default",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/owner/transactions",
              "host": ["{{baseUrl}}"],
              "path": ["owner", "transactions"]
            },
            "description": "Fetch owner transactions with default pagination (page=1, limit=20)."
          }
        },
        {
          "name": "GET /owner/transactions — With Filters",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/owner/transactions?status=PAID&paymentMethod=CASH&page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["owner", "transactions"],
              "query": [
                { "key": "status", "value": "PAID" },
                { "key": "paymentMethod", "value": "CASH" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            },
            "description": "Fetch paid cash transactions, page 1, limit 10."
          }
        },
        {
          "name": "GET /owner/transactions — Date Range",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/owner/transactions?startDate=2024-01-01T00:00:00Z&endDate=2024-02-01T00:00:00Z",
              "host": ["{{baseUrl}}"],
              "path": ["owner", "transactions"],
              "query": [
                { "key": "startDate", "value": "2024-01-01T00:00:00Z" },
                { "key": "endDate", "value": "2024-02-01T00:00:00Z" }
              ]
            },
            "description": "Fetch transactions in January 2024 (startDate inclusive, endDate exclusive)."
          }
        },
        {
          "name": "GET /owner/transactions — Search",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/owner/transactions?search=MEM-123",
              "host": ["{{baseUrl}}"],
              "path": ["owner", "transactions"],
              "query": [{ "key": "search", "value": "MEM-123" }]
            },
            "description": "Search transactions by orderId substring."
          }
        },
        {
          "name": "GET /owner/transactions — By Kiosk",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/owner/transactions?kioskId={{kioskId}}",
              "host": ["{{baseUrl}}"],
              "path": ["owner", "transactions"],
              "query": [{ "key": "kioskId", "value": "{{kioskId}}" }]
            },
            "description": "Filter transactions by kiosk ID."
          }
        }
      ]
    },
    {
      "name": "Wallet",
      "item": [
        {
          "name": "GET /owner/wallet — Default",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/owner/wallet",
              "host": ["{{baseUrl}}"],
              "path": ["owner", "wallet"]
            },
            "description": "Get wallet balance and mutation history (page=1, limit=20)."
          }
        },
        {
          "name": "GET /owner/wallet — Custom Pagination",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/owner/wallet?page=2&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["owner", "wallet"],
              "query": [{ "key": "page", "value": "2" }, { "key": "limit", "value": "10" }]
            },
            "description": "Get wallet mutations page 2, 10 items per page."
          }
        }
      ]
    },
    {
      "name": "Withdrawals",
      "item": [
        {
          "name": "POST /owner/withdrawals — Request",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 50000,\n  \"bankName\": \"BCA\",\n  \"bankAccountNumber\": \"1234567890\",\n  \"bankAccountName\": \"Studio Owner\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/owner/withdrawals",
              "host": ["{{baseUrl}}"],
              "path": ["owner", "withdrawals"]
            },
            "description": "Request a new withdrawal. Only 1 PENDING withdrawal allowed per owner."
          }
        },
        {
          "name": "GET /owner/withdrawals — List",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/owner/withdrawals",
              "host": ["{{baseUrl}}"],
              "path": ["owner", "withdrawals"]
            },
            "description": "List all withdrawals for the owner (default pagination)."
          }
        },
        {
          "name": "GET /owner/withdrawals — Paginated",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/owner/withdrawals?page=1&limit=5",
              "host": ["{{baseUrl}}"],
              "path": ["owner", "withdrawals"],
              "query": [{ "key": "page", "value": "1" }, { "key": "limit", "value": "5" }]
            },
            "description": "List withdrawals with custom pagination."
          }
        }
      ]
    }
  ]
}
