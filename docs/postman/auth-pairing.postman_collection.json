{
  "info": {
    "name": "memoir. API — Auth & Pairing (EPIC-01)",
    "description": "Auth endpoints for memoir. platform backend.\n\nEndpoints:\n- POST /auth/login — Login admin/owner\n- POST /auth/refresh — Refresh access token (via cookie)\n- POST /auth/logout — Revoke refresh token + clear cookie\n- POST /kiosk/pair — Pair kiosk device with 6-digit code",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api/v1",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "deviceToken",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('accessToken', body.data.accessToken);",
                  "  pm.test('Login success — has accessToken', () => {",
                  "    pm.expect(body.data.accessToken).to.be.a('string');",
                  "  });",
                  "  pm.test('Login success — has user', () => {",
                  "    pm.expect(body.data.user.id).to.be.a('string');",
                  "    pm.expect(body.data.user.email).to.be.a('string');",
                  "    pm.expect(body.data.user.role).to.be.oneOf(['platform_admin', 'studio_owner']);",
                  "  });",
                  "  pm.test('Set-Cookie contains refresh_token', () => {",
                  "    const cookies = pm.response.headers.get('Set-Cookie');",
                  "    pm.expect(cookies).to.include('refresh_token');",
                  "  });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"owner@memoir.id\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "description": "Login admin or studio owner. Returns JWT access token in body and sets refresh_token as HttpOnly cookie.\n\nRate limit: 5 req/min per IP."
          }
        },
        {
          "name": "Login — Invalid credentials",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"wrong@example.com\",\n  \"password\": \"wrongpassword\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "description": "Expected: 401 Unauthorized"
          }
        },
        {
          "name": "Login — Validation error",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"not-an-email\",\n  \"password\": \"\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "description": "Expected: 400 Validation Error"
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('accessToken', body.data.accessToken);",
                  "  pm.test('Refresh success — has new accessToken', () => {",
                  "    pm.expect(body.data.accessToken).to.be.a('string');",
                  "  });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "refresh"]
            },
            "description": "Get new access token using refresh_token cookie (sent automatically by browser/Postman). No body required.\n\nRate limit: 10 req/min per IP."
          }
        },
        {
          "name": "Refresh Token — No cookie",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "refresh"]
            },
            "description": "Expected: 401 Unauthorized (no refresh_token cookie)"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "logout"]
            },
            "description": "Revoke refresh token and clear cookie. Returns 204 No Content.\n\nIdempotent — succeeds even without valid cookie.\nRate limit: 10 req/min per IP."
          }
        }
      ]
    },
    {
      "name": "Kiosk Pairing",
      "item": [
        {
          "name": "Pair Kiosk",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('deviceToken', body.data.deviceToken);",
                  "  pm.test('Pair success — has deviceToken', () => {",
                  "    pm.expect(body.data.deviceToken).to.be.a('string');",
                  "  });",
                  "  pm.test('Pair success — has kioskConfig', () => {",
                  "    pm.expect(body.data.kioskConfig.id).to.be.a('string');",
                  "    pm.expect(body.data.kioskConfig.name).to.be.a('string');",
                  "    pm.expect(body.data.kioskConfig.priceBaseSession).to.be.a('number');",
                  "  });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pairingCode\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/kiosk/pair",
              "host": ["{{baseUrl}}"],
              "path": ["kiosk", "pair"]
            },
            "description": "Exchange 6-digit pairing code for a permanent device token. No auth required.\n\nRate limit: 5 req/min per IP."
          }
        },
        {
          "name": "Pair Kiosk — Invalid code",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pairingCode\": \"000000\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/kiosk/pair",
              "host": ["{{baseUrl}}"],
              "path": ["kiosk", "pair"]
            },
            "description": "Expected: 404 Not Found"
          }
        },
        {
          "name": "Pair Kiosk — Bad format",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pairingCode\": \"12\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/kiosk/pair",
              "host": ["{{baseUrl}}"],
              "path": ["kiosk", "pair"]
            },
            "description": "Expected: 400 Validation Error (must be exactly 6 chars)"
          }
        }
      ]
    }
  ]
}
